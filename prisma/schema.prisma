generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  ADMIN
  USER
}

enum TradeDirection {
  LONG
  SHORT
}

enum TradeOutcome {
  PENDING
  HIT_TARGET
  STOPPED_OUT
  PARTIAL
  INVALIDATED
}

enum EkubCycleFrequency {
  WEEKLY
  MONTHLY
}

enum EkubPayoutMethod {
  FIXED_ROTATION
  RANDOM_DRAW
}

enum EkubParticipantStatus {
  ACTIVE
  INACTIVE
}

enum EkubCycleStatus {
  UPCOMING
  OPEN
  COMPLETED
}

model User {
  id                   Int              @id @default(autoincrement())
  name                 String?
  username             String           @unique
  email                String?          @unique
  passwordHash         String
  role                 UserRole         @default(USER)
  publicTradingProfile Boolean          @default(false)
  tradingBio           String?
  tradingFocus         String?
  alpacaPreferredEnvironment String?    @default("paper")
  alpacaLiveAccessTokenEncrypted String?
  alpacaLiveScope      String?
  alpacaLiveConnectedAt DateTime?
  alpacaPaperAccessTokenEncrypted String?
  alpacaPaperScope     String?
  alpacaPaperConnectedAt DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @default(now()) @updatedAt

  tradingSessions TradingSession[]
  tradingJournalEntries TradingJournalEntry[]
  contentDerivatives ContentDerivative[]
  patentRecords PatentRecord[]
  books                Book[]
  ekubGroups           EkubGroup[]
  directMessageThreadsStarted DirectMessageThread[] @relation("DirectMessageStarter")
  directMessageThreadsA DirectMessageThread[] @relation("DirectMessageParticipantA")
  directMessageThreadsB DirectMessageThread[] @relation("DirectMessageParticipantB")
  sentDirectMessages   DirectMessage[]
}

model DirectMessageThread {
  id             Int      @id @default(autoincrement())
  subject        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
  lastMessageAt  DateTime @default(now())

  starterId      Int
  starter        User     @relation("DirectMessageStarter", fields: [starterId], references: [id], onDelete: Cascade)

  participantAId Int
  participantA   User     @relation("DirectMessageParticipantA", fields: [participantAId], references: [id], onDelete: Cascade)

  participantBId Int
  participantB   User     @relation("DirectMessageParticipantB", fields: [participantBId], references: [id], onDelete: Cascade)

  messages       DirectMessage[]

  @@unique([participantAId, participantBId])
}

model DirectMessage {
  id         Int      @id @default(autoincrement())
  body       String
  createdAt  DateTime @default(now())
  readAt     DateTime?

  threadId   Int
  thread     DirectMessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  senderId   Int
  sender     User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Post {
  id         Int       @id @default(autoincrement())
  title      String
  slug       String    @unique
  summary    String?
  body       String
  sourceChat String?
  votes      Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt

  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])
  contentDerivatives ContentDerivative[]
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  posts Post[]
}

model TradingSession {
  id                  Int      @id @default(autoincrement())
  title               String
  slug                String   @unique
  market              String
  timeframe           String
  setupType           String
  direction           TradeDirection
  thesis              String
  summary             String
  entryMin            Float
  entryMax            Float
  stopLoss            Float
  targetOne           Float
  targetTwo           Float?
  confidence          Int
  outcome             TradeOutcome @default(PENDING)
  sourceChat          String?
  setupContext        String?
  workflowNotes       String?
  personalizedInsight String?
  featuredPublic      Boolean  @default(false)
  votes               Int      @default(0)
  suggestionCount     Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @default(now()) @updatedAt

  authorId Int
  author   User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  contentDerivatives ContentDerivative[]
}

model TradingJournalEntry {
  id             Int      @id @default(autoincrement())
  title          String
  slug           String   @unique
  market         String
  timeframe      String
  direction      TradeDirection
  entryDate      DateTime
  exitDate       DateTime?
  entryPrice     Float
  exitPrice      Float?
  summary        String
  executionNotes String?
  mistakeReview  String?
  lessonLearned  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  authorId Int
  author   User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model ContentDerivative {
  id              Int      @id @default(autoincrement())
  channel         String
  format          String
  title           String
  body            String
  metadata        String?
  status          String   @default("draft")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  authorId        Int
  author          User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  postId          Int?
  post            Post? @relation(fields: [postId], references: [id], onDelete: Cascade)

  tradingSessionId Int?
  tradingSession  TradingSession? @relation(fields: [tradingSessionId], references: [id], onDelete: Cascade)
}

model PatentRecord {
  id                    Int      @id @default(autoincrement())
  title                 String
  slug                  String   @unique
  inventorNames         String
  problem               String
  solution              String
  novelty               String
  useCases              String?
  alternatives          String?
  figureNotes           String?
  publicDisclosureState String
  provisionalFiledAt    DateTime?
  provisionalDeadline   DateTime?
  packetBody            String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now()) @updatedAt

  authorId Int
  author   User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Book {
  id           Int      @id @default(autoincrement())
  title        String
  slug         String   @unique
  bookType     String
  isPublic     Boolean  @default(false)
  targetLength String?
  audience     String?
  tone         String?
  summary      String?
  outline      String?
  sourceDraft  String
  authorNotes  String?
  storySynopsis       String?
  storyChapterCount   Int?
  storyStructureNotes String?
  characterProfilesJson String?
  settingProfilesJson   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  authorId Int
  author   User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  sections BookSection[]
}

model BookSection {
  id              Int      @id @default(autoincrement())
  kind            String
  title           String
  summary         String?
  content         String
  characterIdsJson String?
  settingIdsJson   String?
  sceneGoal        String?
  sceneConflict    String?
  povCharacterId   String?
  position        Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  parentSectionId Int?

  bookId Int
  book   Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  parentSection BookSection?  @relation("BookSectionChildren", fields: [parentSectionId], references: [id], onDelete: Cascade)
  subsections   BookSection[] @relation("BookSectionChildren")
}

model EkubGroup {
  id                    Int                @id @default(autoincrement())
  name                  String
  description           String?
  contributionAmount    Float
  cycleFrequency        EkubCycleFrequency
  maxParticipants       Int
  payoutMethod          EkubPayoutMethod
  reputationScore       Float?
  reserveLogic          String?
  feeLogic              String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @default(now()) @updatedAt

  ownerId               Int
  owner                 User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  participants          EkubParticipant[]
  cycles                EkubCycle[]
}

model EkubParticipant {
  id                    Int                   @id @default(autoincrement())
  name                  String
  email                 String?
  status                EkubParticipantStatus @default(ACTIVE)
  rotationOrder         Int?
  reputationScore       Float?
  walletAddress         String?
  notes                 String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @default(now()) @updatedAt

  groupId               Int
  group                 EkubGroup             @relation(fields: [groupId], references: [id], onDelete: Cascade)

  contributions         EkubContribution[]
  wonCycles             EkubCycle[]           @relation("EkubCycleRecipient")
  payouts               EkubPayout[]          @relation("EkubPayoutRecipient")

  @@unique([groupId, rotationOrder])
}

model EkubCycle {
  id                         Int             @id @default(autoincrement())
  cycleNumber                Int
  dueDate                    DateTime
  totalExpectedContribution  Float
  totalCollected             Float           @default(0)
  status                     EkubCycleStatus @default(UPCOMING)
  recipientParticipantId     Int?
  drawRunAt                  DateTime?
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @default(now()) @updatedAt

  groupId                    Int
  group                      EkubGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)

  recipient                  EkubParticipant? @relation("EkubCycleRecipient", fields: [recipientParticipantId], references: [id], onDelete: SetNull)
  contributions              EkubContribution[]
  payout                     EkubPayout?

  @@unique([groupId, cycleNumber])
}

model EkubContribution {
  id                 Int             @id @default(autoincrement())
  amountPaid         Float           @default(0)
  paidAt             DateTime?
  isPaid             Boolean         @default(false)
  notes              String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @default(now()) @updatedAt

  cycleId            Int
  cycle              EkubCycle       @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  participantId      Int
  participant        EkubParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([cycleId, participantId])
}

model EkubPayout {
  id                    Int             @id @default(autoincrement())
  amountPaidOut         Float
  payoutDate            DateTime
  notes                 String?
  transactionHash       String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @default(now()) @updatedAt

  cycleId               Int             @unique
  cycle                 EkubCycle       @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  recipientParticipantId Int
  recipient             EkubParticipant @relation("EkubPayoutRecipient", fields: [recipientParticipantId], references: [id], onDelete: Restrict)
}
